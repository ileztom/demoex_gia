<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.demo_ex.controller.OrderEditController" prefWidth="400" prefHeight="450">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Text fx:id="titleText" text="Заказ" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="ID"/>
    <TextField fx:id="txtId" editable="false"/>

    <Label text="Артикул"/>
    <TextField fx:id="txtArticle"/>

    <Label text="Статус"/>
    <ComboBox fx:id="cmbStatus" prefWidth="250"/>

    <Label text="Адрес пункта выдачи"/>
    <TextField fx:id="txtAddress"/>

    <Label text="Дата заказа"/>
    <DatePicker fx:id="dpOrderDate"/>

    <Label text="Дата выдачи"/>
    <DatePicker fx:id="dpReceiveDate"/>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="btnSave" text="Сохранить" onAction="#onSave" prefWidth="120"/>
        <Button fx:id="btnCancel" text="Отмена" onAction="#onCancel" prefWidth="120"/>
    </HBox>
</VBox>
