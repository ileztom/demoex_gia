<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.demo_ex.controller.OrderListController" prefWidth="800" prefHeight="500">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Text text="Список заказов" style="-fx-font-size: 20px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblUser" text="" style="-fx-font-size: 14px;"/>
        <Button text="Назад" onAction="#onBack"/>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="btnAddOrder" text="Добавить заказ" onAction="#onAddOrder"/>
        <Button fx:id="btnDeleteOrder" text="Удалить заказ" onAction="#onDeleteOrder"/>
    </HBox>

    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Артикул" prefWidth="150">
                <cellValueFactory><PropertyValueFactory property="article"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Статус" prefWidth="150">
                <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Адрес пункта выдачи" prefWidth="200">
                <cellValueFactory><PropertyValueFactory property="pickupPoint"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Дата заказа" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="orderDate"/></cellValueFactory>
            </TableColumn>
            <TableColumn text="Дата выдачи" prefWidth="120">
                <cellValueFactory><PropertyValueFactory property="receiveDate"/></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>
</VBox>
